<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0069C0"
    android:padding="8dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Platos"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"/>

    <!-- Campo de búsqueda por ingrediente -->
    <EditText
        android:id="@+id/etIngrediente"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Buscar por ingrediente..."
        android:textColorHint="#BBDEFB"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Botón buscar -->
    <Button
        android:id="@+id/btnBuscar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Buscar"
        android:textColor="#0069C0"
        android:backgroundTint="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <!-- Clase 5.1 — RecyclerView para mostrar meals -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMeals"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>