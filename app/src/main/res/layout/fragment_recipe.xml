<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0069C0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Receta"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp"/>

        <!-- Indicación al usuario -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingrese el ID del plato para ver su receta completa."
            android:textColor="#BBDEFB"
            android:textSize="13sp"
            android:layout_marginBottom="4dp"/>

        <!-- Ejemplo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ej: 52959, 52772, 52846"
            android:textColor="#BBDEFB"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginBottom="12dp"/>

        <!-- Campo para ID del plato -->
        <EditText
            android:id="@+id/etMealId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ingrese ID del plato..."
            android:textColorHint="#BBDEFB"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FFFFFF"
            android:inputType="number"
            android:layout_marginBottom="8dp"/>

        <!-- Botón buscar receta -->
        <Button
            android:id="@+id/btnBuscarReceta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Buscar Receta"
            android:textColor="#0069C0"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Imagen del plato -->
        <ImageView
            android:id="@+id/ivMealDetail"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Nombre del plato -->
        <TextView
            android:id="@+id/tvMealName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Categoría -->
        <TextView
            android:id="@+id/tvMealCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBDEFB"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Área/Origen -->
        <TextView
            android:id="@+id/tvMealArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBDEFB"
            android:textSize="16sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Ingredientes título -->
        <TextView
            android:id="@+id/tvIngredientes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingredientes:"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Ingredientes contenido -->
        <TextView
            android:id="@+id/tvMealIngredients"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBDEFB"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="12dp"/>

        <!-- Instrucciones título -->
        <TextView
            android:id="@+id/tvInstrucciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Instrucciones:"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="4dp"/>

        <!-- Instrucciones contenido -->
        <TextView
            android:id="@+id/tvMealInstructions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BBDEFB"
            android:textSize="14sp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</ScrollView>